{
  "name": "TestOpos - Oposiciones con IA",
  "short_name": "TestOpos",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#f9fafb",
  "theme_color": "#2563eb",
  "description": "Practica para tus oposiciones con exámenes reales o tests generados por IA.",
  "icons": [
    {
      "src": "/icons/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "/icons/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png"
    },
    {
      "src": "/icons/icon-maskable-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/icons/icon-maskable-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "id": "/?utm_source=pwa",
  "orientation": "portrait",
  "screenshots": [
    {
      "src": "/screenshots/screenshot1.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Página de Inicio"
    },
    {
      "src": "/screenshots/screenshot2.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Página de Test"
    }
  ],
  "shortcuts": [
    {
      "name": "Generar Test con IA",
      "short_name": "Generar IA",
      "description": "Crea un nuevo test personalizado con inteligencia artificial.",
      "url": "/generate",
      "icons": [
        {
          "src": "/icons/shortcut-generate.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Ver Estadísticas",
      "short_name": "Estadísticas",
      "description": "Revisa tu progreso y resultados de los tests.",
      "url": "/stats",
      "icons": [
        {
          "src": "/icons/shortcut-stats.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    }
  ],
  "categories": [
    "education",
    "productivity"
  ],
  "scope": "/",
  "lang": "es-ES",
  "dir": "ltr",
  "display_override": [
    "standalone",
    "minimal-ui"
  ],
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.example.testopos",
      "id": "com.example.testopos"
    }
  ],
  "prefer_related_applications": false,
  "file_handlers": [
    {
      "action": "/handle-files",
      "accept": {
        "application/pdf": [
          ".pdf"
        ]
      }
    }
  ],
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "protocol_handlers": [
    {
      "protocol": "web+testopos",
      "url": "/protocol-handler?q=%s"
    }
  ],
  "share_target": {
    "action": "/share-target",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",
  "widgets": [
    {
      "name": "Resumen de Estadísticas",
      "description": "Ver tu progreso reciente.",
      "tag": "stats-summary",
      "template": "stats-widget",
      "ms_ac_template": "widgets/stats-template.json",
      "data": "widgets/stats-data.json",
      "type": "application/json"
    }
  ],
  "edge_side_panel": {
    "preferred_width": 400
  },
  "note_taking": {
    "new_note_url": "/new-note",
    "needs_editing_permission": true
  },
  "scope_extensions": [
    { "origin": "*.testopos.com" },
    { "origin": "*.testopos.es" }
  ]
}