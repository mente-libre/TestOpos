{
  "name": "TestOpos",
  "short_name": "TestOpos",
  "description": "Practica para tus oposiciones con tests reales y exámenes generados por inteligencia artificial. Analiza tu progreso y mejora tus resultados.",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "#2563eb",
  "icons": [
    {
      "src": "/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png"
    },
    {
      "src": "/icon-maskable-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/icon-maskable-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "https://picsum.photos/seed/1/1080/1920",
      "type": "image/jpeg",
      "sizes": "1080x1920",
      "form_factor": "narrow"
    },
    {
      "src": "https://picsum.photos/seed/2/1920/1080",
      "type": "image/jpeg",
      "sizes": "1920x1080",
      "form_factor": "wide"
    }
  ],
  "categories": ["education", "utilities"],
  "id": "/?v=1",
  "orientation": "portrait-primary",
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.example.testopos",
      "id": "com.example.testopos"
    },
    {
      "platform": "itunes",
      "url": "https://itunes.apple.com/app/example-testopos/id123456789"
    }
  ],
  "prefer_related_applications": false,
  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",
  "display_override": ["window-controls-overlay", "minimal-ui"],
  "lang": "es-ES",
  "dir": "ltr",
  "scope": "/",
  "shortcuts": [
    {
      "name": "Generar Test con IA",
      "short_name": "Generar",
      "description": "Crear un nuevo test de oposiciones usando inteligencia artificial",
      "url": "/generate",
      "icons": [{ "src": "/icon-192x192.png", "sizes": "192x192" }]
    }
  ],
  "file_handlers": [
    {
      "action": "/handle-test-file",
      "accept": {
        "application/json": [".testopos"]
      }
    }
  ],
  "share_target": {
    "action": "/share-handler",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "files",
          "accept": ["application/json"]
        }
      ]
    }
  },
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "protocol_handlers": [
    {
      "protocol": "web+testopos",
      "url": "/protocol-handler?test=%s"
    }
  ],
  "widgets": [
    {
      "name": "Últimos Resultados",
      "description": "Widget para ver tus últimos resultados.",
      "tag": "results",
      "template": "results-template",
      "ms_ac_template": "widgets/results.json",
      "data": "widgets/results-data.json",
      "type": "application/ms-adaptive-card"
    }
  ],
  "edge_side_panel": {
    "preferred_width": 480
  },
  "note_taking": {
    "new_note_url": "/new-note",
    "needs_editing_surface": true
  },
  "scope_extensions": [
    { "origin": "*.test-opos.vercel.app" },
    { "origin": "test-opos.firebaseapp.com" }
  ]
}