    "window-controls-overlay",
    "standalone"
  ],
  "background_color": "#f9fafb",
  "theme_color": "#2563eb",
  "orientation": "any",
  "dir": "ltr",
  "lang": "es-ES",
  "scope": "/",
  "icons": [
