  "shortcuts": [
    {
      "name": "Generar Nuevo Test",
      "short_name": "Generar",
      "description": "Crear un nuevo test con IA",
      "url": "/generate",
      "icons": [
        {
          "src": "/icons/shortcut-generate.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Ver Estadísticas",
      "short_name": "Estadísticas",
      "description": "Revisar tu progreso y resultados",
      "url": "/stats",
      "icons": [
        {
          "src": "/icons/shortcut-stats.png",
          "sizes": "96x96"
        }
      ]
    }
  ],
  "share_target": {
    "action": "/share-handler",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "name",
      "text": "description",
      "url": "link",
      "files": [
        {
          "name": "files",
          "accept": [
            "application/pdf",
            ".pdf"
          ]
        }
      ]
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+testopos",
      "url": "/protocol-handler?action=%s"
    }
  ],
  "launch_handler": {
    "client_mode": "navigate-existing"
  }
}