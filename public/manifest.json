{
  "name": "TestOpos - Tests de Oposiciones con IA",
  "short_name": "TestOpos",
  "description": "Genera tests para oposiciones usando IA y prepárate para el éxito.",
  "start_url": "/",
  "id": "/?utm_source=pwa",
  "display": "standalone",
