{
  "name": "TestOpos",
  "short_name": "TestOpos",
  "description": "Practica para tus oposiciones con tests reales y exámenes generados por inteligencia artificial. Analiza tu progreso y mejora tus resultados.",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "#2563eb",
  "icons": [
    {
      "src": "/icons/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "/icons/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png"
    },
    {
      "src": "/icons/maskable-icon.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "orientation": "portrait",
  "id": "/?source=pwa",
  "scope": "/",
  "lang": "es-ES",
  "dir": "ltr",
  "categories": [
    "education",
    "utilities"
  ],
  "shortcuts": [
    {
      "name": "Generar Test con IA",
      "short_name": "Generar IA",
      "description": "Crea un nuevo test personalizado con inteligencia artificial.",
      "url": "/generate",
      "icons": [
        {
          "src": "/icons/shortcut-icon.png",
          "sizes": "96x96"
        }
      ]
    }
  ],
  "file_handlers": [
    {
      "action": "/handle-file",
      "accept": {
        "application/json": [
          ".json"
        ]
      }
    }
  ],
  "screenshots": [
    {
      "src": "https://picsum.photos/seed/1/1080/1920",
      "sizes": "1080x1920",
      "type": "image/jpeg",
      "form_factor": "narrow",
      "label": "Vista de la aplicación en móvil"
    },
    {
      "src": "https://picsum.photos/seed/2/1280/800",
      "sizes": "1280x800",
      "type": "image/jpeg",
      "form_factor": "wide",
      "label": "Vista de la aplicación en escritorio"
    }
  ],
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.example.app1",
      "id": "com.example.app1"
    },
    {
      "platform": "itunes",
      "url": "https://itunes.apple.com/app/example-app1/id123456789"
    }
  ],
  "prefer_related_applications": false,
  "iarc_rating_id": "e84b072d-8543-4d43-8578-f961a090757a",
  "display_override": [
    "window-controls-overlay",
    "minimal-ui"
  ],
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "protocol_handlers": [
    {
      "protocol": "web+testopos",
      "url": "/protocol?type=%s"
    }
  ],
  "widgets": [
    {
      "name": "Últimos Resultados",
      "description": "Widget para ver tus últimos resultados.",
      "tag": "results",
      "template": "results-template",
      "ms_ac_template": "widgets/results.json",
      "data": "widgets/results-data.json",
      "type": "application/json"
    }
  ],
  "edge_side_panel": {
    "preferred_width": 480
  },
  "note_taking": {
    "new_note_url": "/new-note",
    "new_note_accept": [
      {
        "media_type": "text/html",
        "action": "/new-note-with-content",
        "media_formats": [
          "html"
        ]
      }
    ]
  },
  "scope_extensions": [
    {
      "origin": "*.example.com"
    },
    {
      "origin": "sub.example.com"
    },
    {
      "origin": "example.co.uk"
    }
  ]
}
