  "shortcuts": [
    {
      "name": "Generar Test con IA",
      "short_name": "Generar IA",
      "description": "Crea un nuevo test personalizado con IA",
      "url": "/generate",
      "icons": [
        {
          "src": "/icons/shortcut-generate.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Ver Estadísticas",
      "short_name": "Estadísticas",
      "description": "Revisa tu progreso y resultados",
      "url": "/stats",
      "icons": [
        {
          "src": "/icons/shortcut-stats.png",
          "sizes": "96x96"
        }
      ]
    }
  ],
  "display_override": [
    "standalone",
    "minimal-ui"
  ],
  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-32a3ac449730",
  "share_target": {
    "action": "/share-target",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.example.app1",
      "id": "com.example.app1"
    }
  ],
  "prefer_related_applications": false,
  "protocol_handlers": [
    {
      "protocol": "web+testopos",
      "url": "/protocol?q=%s"
    }
  ],
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "file_handlers": [
    {
      "action": "/open-file",
      "accept": {
        "text/plain": [
          ".txt"
        ]
      }
    }
  ],
  "widgets": [
    {
      "name": "Estadísticas Rápidas",
      "description": "Ver tu puntuación media.",
      "tag": "stats",
      "template": "stats-template",
      "ms_ac_template": "widgets/stats.json",
      "data": "widgets/stats-data.json",
      "type": "application/json",
      "screenshots": [
        {
          "src": "/screenshots/widget-screenshot.png",
          "sizes": "600x400",
          "type": "image/png"
        }
      ],
      "icons": [
        {
          "src": "/icons/widget-icon.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ],
      "auth": false,
      "update": 86400
    }
  ],
  "edge_side_panel": {
    "preferred_width": 480
  },
  "note_taking": {
    "new_note_url": "/new-note",
    "needs_sync": true
  },
  "scope_extensions": [
    {
      "origin": "https://*.test-opos.vercel.app"
    },
    {
      "origin": "https://*.vercel.app"
    }
  ]
}
