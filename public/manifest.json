{
  "name": "TestOpos - Tests de Oposiciones con IA",
  "short_name": "TestOpos",
  "description": "La mejor app para preparar tus oposiciones con tests generados por IA",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "#2563eb",
  "orientation": "portrait-primary",
  "icons": [
    { "src": "/icons/icon-72x72.png", "sizes": "72x72", "type": "image/png" },
    { "src": "/icons/icon-96x96.png", "sizes": "96x96", "type": "image/png" },
    { "src": "/icons/icon-128x128.png", "sizes": "128x128", "type": "image/png" },
    { "src": "/icons/icon-144x144.png", "sizes": "144x144", "type": "image/png" },
    { "src": "/icons/icon-152x152.png", "sizes": "152x152", "type": "image/png" },
    { "src": "/icons/icon-192x192.png", "sizes": "192x192", "type": "image/png", "purpose": "any maskable" },
    { "src": "/icons/icon-384x384.png", "sizes": "384x384", "type": "image/png" },
    { "src": "/icons/icon-512x512.png", "sizes": "512x512", "type": "image/png" }
  ],
  "screenshots": [
    {
      "src": "/screenshots/screenshot1.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "label": "Pantalla de inicio con categorías de exámenes."
    },
    {
      "src": "/screenshots/screenshot2.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "label": "Realizando un test con una pregunta y opciones."
    }
  ],
  "shortcuts": [
    {
      "name": "Generar Nuevo Test",
      "short_name": "Generar",
      "description": "Crea un nuevo test con IA",
      "url": "/generate",
      "icons": [{ "src": "/icons/icon-96x96.png", "sizes": "96x96" }]
    },
    {
      "name": "Ver Estadísticas",
      "short_name": "Estadísticas",
      "description": "Consulta tu progreso y resultados",
      "url": "/stats",
      "icons": [{ "src": "/icons/icon-96x96.png", "sizes": "96x96" }]
    }
  ],
  "categories": ["education", "business"],
  "dir": "ltr",
  "lang": "es-ES",
  "id": "/?source=pwa",
  "scope": "/",
  "display_override": ["standalone", "minimal-ui"],
  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "note_taking": {
    "new_note_url": "/new-note",
    "accept": ["text/plain", "text/html"]
  },
  "protocol_handlers": [
    {
      "protocol": "web+testopos",
      "url": "/test?examId=%s"
    }
  ],
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.example.testopos",
      "id": "com.example.testopos"
    },
    {
      "platform": "itunes",
      "url": "https://itunes.apple.com/app/testopos/id123456789"
    }
  ],
  "prefer_related_applications": false,
  "share_target": {
    "action": "/share-target/",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "file_handlers": [
    {
      "action": "/open-file",
      "accept": {
        "application/pdf": [".pdf"]
      }
    }
  ],
  "edge_side_panel": {
    "preferred_width": 400
  },
  "scope_extensions": [
    { "origin": "*.example.com" },
    { "origin": "https://example.com" }
  ],
  "widgets": [
    {
      "name": "Últimas estadísticas",
      "description": "Widget para ver tu progreso reciente.",
      "tag": "stats-widget",
      "template": "stats-widget-template",
      "ms_ac_template": "widgets/stats.json",
      "data": "widgets/stats-data.json",
      "type": "application/json",
      "screenshots": [
        {
          "src": "/screenshots/widget-screenshot.png",
          "sizes": "600x800",
          "label": "Widget de estadísticas"
        }
      ],
      "icons": [
        {
          "src": "/icons/icon-96x96.png",
          "sizes": "96x96"
        }
      ],
      "auth": false,
      "update": 86400
    }
  ]
}