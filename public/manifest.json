      "src": "/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icon-256x256.png",
      "sizes": "256x256",
      "type": "image/png"
    },
    {
      "src": "/icon-384x384.png",
      "sizes": "384x384",
      "type": "image/png"
    },
    {
      "src": "/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "/screenshots/screenshot1.png",
      "type": "image/png",
      "sizes": "1080x2340",
      "form_factor": "narrow"
    },
    {
      "src": "/screenshots/screenshot2.png",
      "type": "image/png",
      "sizes": "1920x1080",
      "form_factor": "wide"
    }
  ],
  "orientation": "portrait",
  "dir": "ltr",
  "lang": "es-ES",
  "display_override": [
    "standalone"
  ],
  "categories": [
    "education",
    "productivity"
  ],
  "shortcuts": [
    {
      "name": "Generar Test con IA",
      "short_name": "Generar Test",
      "description": "Crea un nuevo test personalizado con inteligencia artificial.",
      "url": "/generate",
      "icons": [
        {
          "src": "/icons/shortcut-generate.png",
          "sizes": "192x192"
        }
      ]
    },
    {
      "name": "Ver Estadísticas",
      "short_name": "Estadísticas",
      "description": "Revisa tu progreso y resultados.",
      "url": "/stats",
      "icons": [
        {
          "src": "/icons/shortcut-stats.png",
          "sizes": "192x192"
        }
      ]
    }
  ],
  "share_target": {
    "action": "/share-target",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.example.testopos",
      "id": "com.example.testopos"
    }
  ],
  "prefer_related_applications": false,
  "launch_handler": {
    "client_mode": [
      "navigate-existing",
      "auto"
    ]
  },
  "protocol_handlers": [
    {
      "protocol": "web+testopos",
      "url": "/protocol?type=%s"
    }
  ],
  "iarc_rating_id": "e84b072d-8686-4c38-8120-03597d31f257",
  "edge_side_panel": {
    "preferred_width": 480
  },
  "note_taking": {
    "new_note_url": "/new-note",
    "needs_editing_permission": true
  },
  "file_handlers": [
    {
      "action": "/open-file",
      "accept": {
        "application/pdf": [
          ".pdf"
        ]
      }
    }
  ],
  "widgets": [
    {
      "name": "Mis Estadísticas (TestOpos)",
      "short_name": "Estadísticas",
      "description": "Consulta tu progreso reciente en TestOpos.",
      "icons": [
        {
          "src": "/icon-192x192.png",
          "sizes": "192x192"
        }
      ],
      "template": "stats-template",
      "tag": "stats"
    }
  ],
  "scope_extensions": [
    {
      "origin": "https://*.test-opos.vercel.app"
    }
  ]
}