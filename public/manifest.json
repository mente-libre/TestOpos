{
  "name": "TestOpos - Tests de Oposiciones con IA",
  "short_name": "TestOpos",
  "description": "Practica con exámenes reales o deja que nuestra IA genere nuevos tests para ti. La preparación más completa a tu alcance.",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#f9fafb",
  "theme_color": "#2563eb",
  "orientation": "portrait",
  "id": "/?source=pwa",
  "scope": "/",
  "lang": "es-ES",
  "dir": "ltr",
  "icons": [
    {
      "src": "/icons/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-maskable-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/icons/icon-maskable-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "/screenshots/screenshot1.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Página de inicio de TestOpos"
    },
    {
      "src": "/screenshots/screenshot2.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Página de un test"
    }
  ],
  "shortcuts": [
    {
      "name": "Generar Test con IA",
      "short_name": "Generar",
      "description": "Crea un nuevo test personalizado con IA",
      "url": "/generate",
      "icons": [{ "src": "/icons/shortcut-generate.png", "sizes": "192x192" }]
    },
    {
      "name": "Ver Estadísticas",
      "short_name": "Estadísticas",
      "description": "Revisa tu progreso y resultados",
      "url": "/stats",
      "icons": [{ "src": "/icons/shortcut-stats.png", "sizes": "192x192" }]
    }
  ],
  "categories": [
    "education",
    "productivity"
  ],
  "file_handlers": [
    {
      "action": "/handle-file",
      "accept": {
        "application/pdf": [".pdf"]
      }
    }
  ],
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "protocol_handlers": [
    {
      "protocol": "web+testopos",
      "url": "/protocol?type=%s"
    }
  ],
  "share_target": {
    "action": "/share-target",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "iarc_rating_id": "e5c89f2b-2f3b-43a7-872b-1b1a7d5b1cb1",
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.example.testopos",
      "id": "com.example.testopos"
    }
  ],
  "prefer_related_applications": false,
  "display_override": [
    "standalone",
    "minimal-ui"
  ],
  "edge_side_panel": {},
  "note_taking": {},
  "scope_extensions": [
    {
      "origin": "*.example.com"
    }
  ],
  "widgets": [
    {
      "name": "Resumen de Estadísticas",
      "description": "Widget para ver tu progreso reciente.",
      "tag": "stats-widget",
      "template": "stats-widget-template",
      "ms_ac_template": "/widgets/stats.html",
      "data": "/widgets/stats-data.json",
      "icons": [
        {
          "src": "/icons/widget-icon.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ],
       "screenshots": [
        {
          "src": "/widgets/screenshot.png",
          "sizes": "1080x1920",
          "type": "image/png",
          "label": "Widget de estadísticas"
        }
      ],
      "auth": false,
      "update": 86400
    }
  ]
}
