      "sizes": "144x144",
      "type": "image/png"
    },
    {
      "src": "/icons/icon-152x152.png",
      "sizes": "152x152",
      "type": "image/png"
    },
    {
      "src": "/icons/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/icons/icon-384x384.png",
      "sizes": "384x384",
      "type": "image/png"
    },
    {
      "src": "/icons/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ],
  "screenshots": [
    {
      "src": "/screenshots/screenshot1.png",
      "sizes": "1280x720",
      "type": "image/png",
      "label": "Pantalla de inicio"
    },
    {
      "src": "/screenshots/screenshot2.png",
      "sizes": "1280x720",
      "type": "image/png",
      "label": "Página de un test"
    }
  ],
  "categories": [
    "education",
    "productivity",
    "utilities"
  ],
  "shortcuts": [
    {
      "name": "Generar nuevo test",
      "short_name": "Generar",
      "description": "Crea un nuevo test con IA",
      "url": "/generate",
      "icons": [
        {
          "src": "/icons/shortcut-generate.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Ver estadísticas",
      "short_name": "Estadísticas",
      "description": "Revisa tu progreso",
      "url": "/stats",
      "icons": [
        {
          "src": "/icons/shortcut-stats.png",
          "sizes": "96x96"
        }
      ]
    }
  ],
  "edge_side_panel": {
    "preferred_width": 400
  },
  "file_handlers": [
    {
      "action": "/handle-file",
      "accept": {
        "application/pdf": [
          ".pdf"
        ]
      },
      "launch_type": "multiple-clients"
    }
  ],
  "launch_handler": {
    "client_mode": [
      "navigate-existing",
      "auto"
    ]
  },
  "note_taking": {
    "new_note_url": "/new-note",
    "edit_note_url": "/edit-note"
  },
  "protocol_handlers": [
    {
      "protocol": "web+testopos",
      "url": "/protocol-handler?action=%s"
    }
  ],
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.example.testopos",
      "id": "com.example.testopos"
    },
    {
      "platform": "itunes",
      "url": "https://itunes.apple.com/app/testopos/id123456789"
    }
  ],
  "prefer_related_applications": false,
  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",
  "share_target": {
    "action": "/share-target/",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "widgets": [
    {
      "name": "Resumen de Progreso",
      "description": "Widget para ver tus últimas estadísticas.",
      "tag": "stats-widget",
      "template": "stats-widget-template",
      "ms_ac_template": "/widgets/stats.json",
      "data": "/widgets/stats-data.json",
      "type": "application/json",
       "icons": [
        {
          "src": "/icons/widget-stats-icon.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ],
      "auth": true
    }
  ],
  "scope_extensions": [
    { "origin": "*.example.com" },
    { "origin": "another-domain.com" }
  ]
}