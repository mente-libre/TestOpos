  ],
  "shortcuts": [
    {
      "name": "Generar Test con IA",
      "url": "/generate",
      "description": "Crea un nuevo test personalizado.",
      "icons": [
        {
          "src": "/icons/shortcut-generate.png",
          "sizes": "96x96"
        }
      ]
    }
  ],
  "share_target": {
    "action": "/share-target/",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "name",
      "text": "description",
      "url": "link",
      "files": [
        {
          "name": "media",
          "accept": [
            "application/json",
            "application/pdf"
          ]
        }
      ]
    }
  },
  "iarc_rating_id": "e84b072d-8686-4c38-812b-346a6843656c",
  "scope_extensions": [
    {
      "origin": "*.vercel.app"
    },
    {
      "origin": "*.google.com"
    }
  ],
  "widgets": [
    {
      "name": "Generador Rápido",
      "description": "Accede directamente al generador de tests.",
      "tag": "generator",
      "template": "generator-template",
      "ms_ac_template": "widgets/generator.json",
      "data": "widgets/generator-data.json",
      "type": "application/json",
      "screenshots": [
        {
          "src": "https://picsum.photos/seed/widget-ss/600/400",
          "sizes": "600x400",
          "label": "Vista previa del widget Generador Rápido"
        }
      ],
      "icons": [
        {
          "src": "/icons/72.png",
          "sizes": "72x72"
        }
      ],
      "auth": false,
      "update": 86400
    }
  ],
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "protocol_handlers": [
    {
      "protocol": "web+opostest",
      "url": "/protocol?type=%s"
    }
  ],
  "edge_side_panel": {
    "preferred_width": 400
  },
  "note_taking": {
    "new_note_url": "/new-note",
    "needs_account": true
  }
}
