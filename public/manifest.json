    },
    {
      "src": "/icons/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    }
  ],
  "screenshots": [
    {
      "src": "/screenshots/screenshot1.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "label": "Página principal con categorías de exámenes."
    },
    {
      "src": "/screenshots/screenshot2.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "label": "Generador de tests con Inteligencia Artificial."
    }
  ],
  "shortcuts": [
    {
      "name": "Generar Test con IA",
      "short_name": "Generar IA",
      "description": "Crea un nuevo test personalizado con IA",
      "url": "/generate",
      "icons": [{ "src": "/icons/shortcut-generate.png", "sizes": "96x96" }]
    },
    {
      "name": "Ver Estadísticas",
      "short_name": "Estadísticas",
      "description": "Revisa tu progreso y resultados",
      "url": "/stats",
      "icons": [{ "src": "/icons/shortcut-stats.png", "sizes": "96x96" }]
    }
  ],
  "file_handlers": [
    {
      "action": "/test",
      "accept": {
        "text/plain": [".txt"]
      }
    }
  ],
  "launch_handler": {
    "client_mode": "focus-existing"
  },
  "protocol_handlers": [
    {
      "protocol": "web+testopos",
      "url": "/test?examId=%s"
    }
  ],
  "prefer_related_applications": false,
  "related_applications": [],
  "share_target": {
    "action": "/shared-content-receiver",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",
  "widgets": [
    {
      "name": "Últimos Resultados",
      "description": "Widget para ver tus últimos resultados.",
      "tag": "results",
      "template": "results-template",
      "ms_ac_template": "widgets/results.json",
      "data": "widgets/results-data.json",
      "type": "application/json"
    }
  ],
  "edge_side_panel": {
    "preferred_width": 480
  },
  "display_override": [
    "standalone"
  ],
  "note_taking": {
    "new_note_url": "/new-note",
    "edit_note_url": "/edit-note"
  },
  "scope_extensions": [
    { "origin": "*.example.com" }
  ]
}
