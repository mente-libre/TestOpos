{
  "name": "TestOpos - Tests de Oposiciones con IA",
  "short_name": "TestOpos",
  "description": "Genera y practica tests para tus oposiciones con la ayuda de la Inteligencia Artificial.",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "#2563eb",
  "orientation": "portrait-primary",
  "lang": "es-ES",
  "dir": "ltr",
  "scope": "/",
  "id": "/?source=pwa",
  "display_override": [
    "standalone",
    "minimal-ui"
  ],
  "categories": [
    "education",
    "productivity",
    "utilities"
  ],
