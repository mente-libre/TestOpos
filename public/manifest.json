{
  "name": "TestOpos - Tests de Oposiciones con IA",
  "short_name": "TestOpos",
  "description": "La mejor app para preparar tus oposiciones con tests reales y generación por IA.",
  "start_url": "/",
  "id": "/?utm_source=pwa",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "minimal-ui"],
  "background_color": "#f9fafb",
  "theme_color": "#2563eb",
  "orientation": "portrait-primary",
  "scope": "/",
  "lang": "es-ES",
  "dir": "ltr",
  "categories": [
    "education",
    "productivity",
    "utilities"
  ],
  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.example.app",
      "id": "com.example.app"
    }
  ],
  "prefer_related_applications": false,
  "launch_handler": {
    "client_mode": ["navigate-existing", "auto"]
  },
  "edge_side_panel": {
    "preferred_width": 480
  },
  "scope_extensions": [
    {"origin": "*.example.com"}
  ],
  "note_taking": {
    "new_note_url": "/new-note",
    "accept": ["text/html", "text/plain"]
  },
  "widgets": [
    {
      "name": "Widget de Últimos Resultados",
      "short_name": "Resultados",
      "description": "Ver tus últimos resultados de tests",
      "tag": "results",
      "template": "results_template",
      "ms_ac_template": "widgets/results.json",
      "data": "widgets/results_data.json",
      "type": "application/json"
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+testopos",
      "url": "/test?id=%s"
    }
  ],
  "file_handlers": [
    {
      "action": "/import-test",
      "accept": {
        "application/json": [".json"]
      }
    }
  ],
  "share_target": {
    "action": "/shared-with-me/",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "shortcuts": [
    {
      "name": "Generar Nuevo Test",
      "short_name": "Generar",
      "description": "Crear un nuevo test con IA",
      "url": "/generate",
      "icons": [
        {
          "src": "/icons/shortcut-generate-96.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Ver Estadísticas",
      "short_name": "Estadísticas",
      "description": "Revisar tu progreso y resultados",
      "url": "/stats",
      "icons": [
        {
          "src": "/icons/shortcut-stats-96.png",
          "sizes": "96x96"
        }
      ]
    }
  ],
  "icons": [
    {
      "src": "/icons/icon-48x48.png",
      "sizes": "48x48",
      "type": "image/png"
    },
    {
      "src": "/icons/icon-72x72.png",
      "sizes": "72x72",
      "type": "image/png"
    },
    {
      "src": "/icons/icon-96x96.png",
      "sizes": "96x96",
      "type": "image/png"
    },
    {
      "src": "/icons/icon-128x128.png",
      "sizes": "128x128",
      "type": "image/png"
    },
    {
      "src": "/icons/icon-144x144.png",
