{
  "name": "TestOpos - Tests de Oposiciones con IA",
  "short_name": "TestOpos",
  "description": "Practica y genera tests para tus oposiciones con la ayuda de la inteligencia artificial. Prepárate de forma inteligente.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "#2563eb",
