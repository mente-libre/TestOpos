{
  "theme_color": "#2563eb",
  "background_color": "#f9fafb",
  "display": "standalone",
  "scope": "/",
  "start_url": "/",
  "name": "TestOpos - Oposiciones con IA",
  "short_name": "TestOpos",
  "description": "Practica para tus oposiciones con tests reales o generados por IA. Mejora tus resultados y prepárate de la forma más completa.",
  "icons": [
    {
      "src": "/icons/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "/icons/icon-256x256.png",
      "sizes": "256x256",
      "type": "image/png"
    },
    {
      "src": "/icons/icon-384x384.png",
      "sizes": "384x384",
      "type": "image/png"
    },
    {
      "src": "/icons/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ],
  "screenshots": [
    {
      "src": "/screenshots/screenshot1.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Vista de la página de inicio"
    },
    {
      "src": "/screenshots/screenshot2.png",
      "sizes": "720x1280",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Vista de un examen en móvil"
    }
  ],
  "shortcuts": [
    {
      "name": "Generar Test con IA",
      "url": "/generate",
      "description": "Crea un nuevo test personalizado con IA."
    },
    {
      "name": "Ver Estadísticas",
      "url": "/stats",
      "description": "Revisa tu progreso y resultados."
    }
  ],
  "id": "/",
  "orientation": "portrait",
  "dir": "auto",
  "lang": "es-ES",
  "categories": ["education", "productivity"],
  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",
  "display_override": ["standalone", "minimal-ui", "tabbed"],
  "edge_side_panel": {
    "preferred_width": 480
  },
  "note_taking": {
    "new_note_url": "/new-note",
    "prevent_sharing": false
  },
  "protocol_handlers": [
    {
      "protocol": "web+testopos",
      "url": "/protocol?q=%s"
    }
  ],
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "files",
          "accept": ["application/pdf", "image/*"]
        }
      ]
    }
  },
  "prefer_related_applications": false,
  "file_handlers": [
    {
      "action": "/open-file",
      "accept": {
        "application/pdf": [".pdf"],
        "text/plain": [".txt"]
      },
      "launch_type": "single-client"
    }
  ],
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.example.testopos",
      "id": "com.example.testopos"
    },
    {
      "platform": "itunes",
      "url": "https://itunes.apple.com/app/testopos/id123456789"
    }
  ],
  "widgets": [
    {
      "name": "Mis Estadísticas",
      "description": "Widget para ver tus últimas estadísticas.",
      "tag": "stats-widget",
      "template": "stats-template",
      "ms_ac_template": "widgets/stats.json",
      "data": "widgets/stats-data.json",
      "type": "application/json",
      "screenshots": [
        {
          "src": "/widgets/stats-preview.png",
          "sizes": "600x600",
          "label": "Vista previa del widget de estadísticas"
        }
      ],
      "auth": false,
      "update": 86400
    }
  ],
  "scope_extensions": [
    {
      "origin": "*.testopos.com"
    },
    {
      "origin": "testopos.es"
    }
  ]
}