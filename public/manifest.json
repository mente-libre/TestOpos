    },
    {
      "src": "/icons/icon-128x128.png",
      "sizes": "128x128",
      "type": "image/png"
    },
    {
      "src": "/icons/icon-144x144.png",
      "sizes": "144x144",
      "type": "image/png"
    },
    {
      "src": "/icons/icon-152x152.png",
      "sizes": "152x152",
      "type": "image/png"
    },
    {
      "src": "/icons/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/icons/icon-384x384.png",
      "sizes": "384x384",
      "type": "image/png"
    },
    {
      "src": "/icons/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ],
  "screenshots": [
    {
      "src": "/screenshots/screenshot1.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "label": "Pantalla de inicio"
    },
    {
      "src": "/screenshots/screenshot2.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "label": "Realizando un test"
    }
  ],
  "shortcuts": [
    {
      "name": "Generar Test con IA",
      "short_name": "Generar Test",
      "description": "Crea un nuevo test personalizado con IA.",
      "url": "/generate",
      "icons": [
        {
          "src": "/icons/shortcut-generate.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Ver Estadísticas",
      "short_name": "Estadísticas",
      "description": "Revisa tu progreso y resultados.",
      "url": "/stats",
      "icons": [
        {
          "src": "/icons/shortcut-stats.png",
          "sizes": "96x96"
        }
      ]
    }
  ],
  "share_target": {
    "action": "/share-target",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.example.testopos",
      "id": "com.example.testopos"
    }
  ],
  "prefer_related_applications": false,
  "protocol_handlers": [
    {
      "protocol": "web+testopos",
      "url": "/protocol-handler?q=%s"
    }
  ],
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "file_handlers": [
    {
      "action": "/open-file",
      "accept": {
        "text/plain": [".txt"]
      }
    }
  ],
  "note_taking": {
    "new_note_url": "/new-note"
  },
  "edge_side_panel": {
    "preferred_width": 400
  },
  "widgets": [
    {
      "name": "Estadísticas Rápidas",
      "description": "Ver tu puntuación media",
      "tag": "stats",
      "template": "stats-template",
      "ms_ac_template": "templates/widget.json",
      "data": "data/widget.json",
      "type": "application/json",
      "icons": [
        {
          "src": "/icons/widget-icon.png",
          "sizes": "128x128"
        }
      ],
      "screenshots": [
        {
          "src": "/screenshots/widget-screenshot.png",
          "sizes": "300x200",
          "label": "Widget de Estadísticas"
        }
      ],
      "auth": false,
      "update": 86400
    }
  ],
  "scope_extensions": [
    { "origin": "https://*.test-opos.vercel.app" }
  ]
}
