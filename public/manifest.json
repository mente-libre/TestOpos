  "categories": ["education", "productivity"],
  "display_override": ["window-controls-overlay", "minimal-ui"],
  "edge_side_panel": {
    "preferred_width": 480
  },
  "file_handlers": [
    {
      "action": "/handle-pdf",
      "accept": {
        "application/pdf": [".pdf"]
      },
      "icons": [
        {
          "src": "/icons/pdf-handler.png",
          "sizes": "128x128"
        }
      ],
      "launch_type": "single-client"
    }
  ],
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "note_taking": {
    "new_note_url": "/new-note",
    "edit_note_url": "/edit-note"
  },
  "protocol_handlers": [
    {
      "protocol": "web+testopos",
      "url": "/protocol-handler?path=%s"
    }
  ],
  "scope_extensions": [
    { "origin": "*.testopos.com" },
    { "origin": "testopos.co.uk" }
  ],
  "share_target": {
    "action": "/share-handler/",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "widgets": [
    {
      "name": "Resumen de Estadísticas",
      "description": "Widget para ver tu progreso reciente.",
      "tag": "stats-widget",
      "template": "stats_widget",
      "ms_ac_template": "/widgets/stats_template.json",
      "data": "/widgets/stats_data.json",
      "screenshots": [
        {
          "src": "/widgets/stats_screenshot.png",
          "sizes": "600x400",
          "label": "Widget de Estadísticas"
        }
      ],
      "icons": [
        {
          "src": "/widgets/stats_icon.png",
          "sizes": "96x96"
        }
      ],
      "auth": false,
      "update": 86400
    }
  ]
}
