{
  "name": "TestOpos - Tests de Oposiciones con IA",
  "short_name": "TestOpos",
  "description": "La mejor app para preparar tus oposiciones con exámenes reales y tests generados por IA.",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "#2563eb",
  "icons": [
    {
      "src": "/icons/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/icons/icon-384x384.png",
      "sizes": "384x384",
      "type": "image/png"
    },
    {
      "src": "/icons/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ],
  "screenshots": [
    {
      "src": "/screenshots/screenshot-desktop-1.jpg",
      "sizes": "1280x720",
      "type": "image/jpeg",
      "form_factor": "wide",
      "label": "Vista de la página principal en escritorio"
    },
    {
      "src": "/screenshots/screenshot-mobile-1.jpg",
      "sizes": "540x720",
      "type": "image/jpeg",
      "form_factor": "narrow",
      "label": "Vista de la página principal en móvil"
    }
  ],
  "orientation": "portrait-primary",
  "scope": "/",
  "lang": "es-ES",
  "id": "/?source=pwa",
  "dir": "ltr",
  "categories": [
    "education",
    "utilities"
  ],
  "display_override": [
    "standalone",
    "window-controls-overlay"
  ],
  "edge_side_panel": {
    "preferred_width": 480
  },
  "iarc_rating_id": "e84b072d-8685-4129-9e13-102434926b42",
  "launch_handler": {
    "client_mode": [
      "navigate-existing",
      "auto"
    ]
  },
  "note_taking": {
    "new_note_url": "/new-note",
    "accept": [
      "text/plain",
      "text/html"
    ]
  },
  "prefer_related_applications": false,
  "protocol_handlers": [
    {
      "protocol": "web+testopos",
      "url": "/test?id=%s"
    }
  ],
  "related_applications": [],
  "scope_extensions": [
    {
      "origin": "*.testopos.com"
    },
    {
      "origin": "testopos.es"
    }
  ],
  "share_target": {
    "action": "/shared-content-receiver/",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "shortcuts": [
    {
      "name": "Generar Nuevo Test",
      "short_name": "Generar",
      "description": "Crear un nuevo test con IA",
      "url": "/generate",
      "icons": [
        {
          "src": "/icons/shortcut-generate.png",
          "sizes": "192x192"
        }
      ]
    },
    {
      "name": "Ver Estadísticas",
      "short_name": "Estadísticas",
      "description": "Revisar tu progreso y resultados",
      "url": "/stats",
      "icons": [
        {
          "src": "/icons/shortcut-stats.png",
          "sizes": "192x192"
        }
      ]
    }
  ],
  "widgets": [
    {
      "name": "Resumen de Estadísticas",
      "description": "Widget que muestra un resumen de tu progreso.",
      "tag": "stats-summary",
      "template": "stats-widget",
      "ms_ac_template": "/widgets/stats.json",
      "data": "/widgets/stats-data.json",
      "type": "application/json",
      "screenshots": [
        {
          "src": "/screenshots/widget-stats.png",
          "sizes": "320x160"
        }
      ],
      "icons": [
        {
          "src": "/icons/widget-icon.png",
          "sizes": "96x96"
        }
      ],
      "auth": "true",
      "update": 86400
    }
  ]
}