{
  "name": "TestOpos - Tests de Oposiciones con IA",
  "short_name": "TestOpos",
  "description": "Genera tests para oposiciones usando IA y prepárate de forma inteligente.",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "#2563eb",
  "icons": [
    {
      "src": "/android-chrome-192x192.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "/android-chrome-512x512.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ],
  "orientation": "portrait",
  "id": "/?v=1",
  "related_applications": [
    {
      "platform": "webapp",
      "url": "https://testopos-app.web.app/manifest.json"
    }
  ],
  "prefer_related_applications": false,
  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",
  "display_override": [
    "window-controls-overlay",
    "tabbed"
  ],
  "lang": "es-ES",
  "dir": "ltr",
  "scope": "/",
  "screenshots": [
    {
      "src": "https://picsum.photos/seed/1/1080/1920",
      "sizes": "1080x1920",
      "type": "image/jpeg",
      "platform": "narrow",
      "label": "Vista principal de la aplicación"
    },
    {
      "src": "https://picsum.photos/seed/2/1080/1920",
      "sizes": "1080x1920",
      "type": "image/jpeg",
      "platform": "narrow",
      "label": "Ejemplo de test en curso"
    }
  ],
  "categories": [
    "education"
  ],
  "shortcuts": [
    {
      "name": "Generar Nuevo Test",
      "short_name": "Generar Test",
      "description": "Crea un nuevo test con preguntas generadas por IA",
      "url": "/generate",
      "icons": [
        {
          "src": "/wand-shortcut-icon.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    }
  ],
  "file_handlers": [
    {
      "action": "/handle-file",
      "accept": {
        "application/json": [
          ".json"
        ]
      },
      "icons": [
        {
          "src": "/file-handler-icon.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ],
      "launch_type": "single-client"
    }
  ],
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "protocol_handlers": [
    {
      "protocol": "web+testopos",
      "url": "/protocol?q=%s"
    }
  ],
  "widgets": [
    {
      "name": "Resumen de Estadísticas",
      "description": "Muestra tus últimas estadísticas de tests.",
      "tag": "stats-widget",
      "template": "stats-widget-template",
      "ms_ac_template": "widgets/stats.json",
      "data": "widgets/stats-data.json",
      "type": "application/json",
      "auth": true,
      "update": 3600
    }
  ],
  "edge_side_panel": {
    "preferred_width": 400
  },
  "note_taking": {
    "new_note_url": "/new-note",
    "accept": [
      "text/html",
      "text/plain"
    ]
  },
  "share_target": {
    "action": "/share-target",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "scope_extensions": [
    { "origin": "*.testopos-app.web.app" },
    { "origin": "*.firebaseapp.com" }
  ]
}