    "productivity",
    "utilities"
  ],
  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",
  "scope_extensions": [
    { "origin": "*.test-opos.vercel.app" },
    { "origin": "test-opos.web.app" },
    { "origin": "test-opos.firebaseapp.com" }
  ],
  "lang": "es-ES",
  "dir": "ltr",
  "id": "/?source=pwa",
  "edge_side_panel": {
    "preferred_width": 400
  },
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "protocol_handlers": [
    {
      "protocol": "web+testopos",
      "url": "/protocol?q=%s"
    }
  ],
  "file_handlers": [
    {
      "action": "/handle-file",
      "accept": {
        "application/pdf": [".pdf"],
        "text/plain": [".txt"]
      }
    }
  ]
