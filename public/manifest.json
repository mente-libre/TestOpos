{
  "name": "TestOpos - Tests de Oposiciones con IA",
  "short_name": "TestOpos",
  "description": "Genera y practica tests para oposiciones usando IA. La preparación más completa a tu alcance.",
  "start_url": "/",
  "id": "/?source=pwa",
  "background_color": "#ffffff",
  "theme_color": "#2563eb",
  "display": "standalone",
  "orientation": "portrait",
  "scope": "/",
  "lang": "es-ES",
  "dir": "ltr",
