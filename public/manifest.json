{
  "name": "TestOpos - Tests de Oposiciones con IA",
  "short_name": "TestOpos",
  "description": "La mejor app para preparar tus oposiciones con tests reales y generados por IA.",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "#2563eb",
  "icons": [
    {
      "src": "/icons/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/icons/icon-384x384.png",
      "sizes": "384x384",
      "type": "image/png"
    },
    {
      "src": "/icons/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ],
  "screenshots": [
    {
      "src": "/screenshots/screenshot-narrow.png",
      "sizes": "540x720",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Vista de la aplicación en móvil"
    },
     {
      "src": "/screenshots/screenshot-wide.png",
      "sizes": "1280x800",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Vista de la aplicación en escritorio"
    }
  ],
  "id": "/?source=pwa",
  "orientation": "any",
  "dir": "auto",
  "lang": "es-ES",
  "scope": "/",
  "display_override": [
    "window-controls-overlay",
    "tabbed"
  ],
  "edge_side_panel": {
    "preferred_width": 480
  },
  "iarc_rating_id": "e5c89f2b-2a3b-4c1c-9076-02d9c1b9a9d7",
  "share_target": {
    "action": "/shared-content-receiver/",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.example.app1",
      "id": "com.example.app1"
    },
    {
      "platform": "itunes",
      "url": "https://itunes.apple.com/app/example-app1/id123456789"
    }
  ],
  "prefer_related_applications": false,
  "protocol_handlers": [
    {
      "protocol": "web+testopos",
      "url": "/protocol?type=%s"
    }
  ],
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "file_handlers": [
    {
      "action": "/handle-pdf",
      "accept": {
        "application/pdf": [
          ".pdf"
        ]
      }
    }
  ],
  "categories": [
    "education",
    "productivity",
    "utilities"
  ],
  "shortcuts": [
    {
      "name": "Generar nuevo test",
      "short_name": "Generar",
      "description": "Crear un nuevo test con IA",
      "url": "/generate",
      "icons": [
        {
          "src": "/icons/shortcut-generate.png",
          "sizes": "192x192"
        }
      ]
    },
    {
      "name": "Ver estadísticas",
      "short_name": "Estadísticas",
      "description": "Revisar tu progreso y resultados",
      "url": "/stats",
      "icons": [
        {
          "src": "/icons/shortcut-stats.png",
          "sizes": "192x192"
        }
      ]
    }
  ],
  "note_taking": {
    "new_note_url": "/new-note",
    "needs_account": true
  },
  "widgets": [
    {
      "name": "Resumen de progreso",
      "description": "Un vistazo rápido a tus últimas puntuaciones.",
      "tag": "summary",
      "template": "summary_template",
      "ms_ac_template": "widgets/summary_template.json",
      "data": "widgets/summary_data.json",
      "type": "application/json"
    }
  ],
  "scope_extensions": [
    {
      "origin": "*.testopos.com"
    },
    {
      "origin": "opos.test.com"
    }
  ]
}