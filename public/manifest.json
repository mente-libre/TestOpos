{
  "name": "TestOpos - Tests de Oposiciones con IA",
  "short_name": "TestOpos",
  "description": "Genera y practica tests para oposiciones usando Inteligencia Artificial. Analiza tu progreso y mejora tus resultados.",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "#2563eb",
  "orientation": "portrait-primary",
  "id": "/?source=pwa",
  "scope": "/",
  "lang": "es-ES",
  "dir": "ltr",
  "display_override": [
    "standalone",
    "minimal-ui"
  ],
  "edge_side_panel": {
    "preferred_width": 480
  },
  "iarc_rating_id": "e84b072d-8685-414a-a352-054625f553a2",
  "note_taking": {
    "new_note_url": "/generate",
    "needs_editing_flag": true
  },
  "share_target": {
    "action": "/share-target",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+testopos",
      "url": "/test?examId=%s"
    }
  ],
  "file_handlers": [
    {
      "action": "/handle-file",
      "accept": {
        "text/plain": [
          ".txt"
        ]
      }
    }
  ],
  "launch_handler": {
    "client_mode": [
      "navigate-existing",
      "auto"
    ]
  },
  "prefer_related_applications": false,
