{
  "name": "TestOpos - Tests de Oposiciones con IA",
  "short_name": "TestOpos",
  "description": "Genera tests para oposiciones usando IA y mejora tus resultados.",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "#2563eb",
  "icons": [
    {
      "src": "/icons/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "/icons/icon-256x256.png",
      "sizes": "256x256",
      "type": "image/png"
    },
    {
      "src": "/icons/icon-384x384.png",
      "sizes": "384x384",
      "type": "image/png"
    },
    {
      "src": "/icons/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ],
  "id": "/?source=pwa",
  "lang": "es-ES",
  "orientation": "portrait-primary",
  "dir": "ltr",
  "scope": "/",
  "categories": [
    "education",
    "productivity"
  ],
  "screenshots": [
    {
      "src": "/screenshots/screenshot1.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Página de Inicio"
    },
    {
      "src": "/screenshots/screenshot2.png",
      "sizes": "1920x1080",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Realizando un Test"
    }
  ],
  "shortcuts": [
    {
      "name": "Generar Nuevo Test",
      "short_name": "Generar Test",
      "description": "Crea un nuevo test con IA",
      "url": "/generate",
      "icons": [
        {
          "src": "/icons/shortcut-generate.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Ver Estadísticas",
      "short_name": "Estadísticas",
      "description": "Revisa tu progreso y resultados",
      "url": "/stats",
      "icons": [
        {
          "src": "/icons/shortcut-stats.png",
          "sizes": "96x96"
        }
      ]
    }
  ],
  "share_target": {
    "action": "/share-target",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "display_override": [
    "standalone",
    "minimal-ui",
    "window-controls-overlay",
    "tabbed"
  ],
  "protocol_handlers": [
    {
      "protocol": "web+testopos",
      "url": "/protocol?q=%s"
    }
  ],
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "edge_side_panel": {
    "preferred_width": 480
  },
  "widgets": [
    {
      "name": "Últimos Resultados",
      "description": "Widget con tus últimas puntuaciones",
      "tag": "results",
      "template": "results_template",
      "ms_ac_template": "widgets/results.json",
      "data": "widgets/results-data.json",
      "type": "application/json"
    }
  ],
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.example.testopos",
      "id": "com.example.testopos"
    },
    {
      "platform": "itunes",
      "url": "https://itunes.apple.com/app/testopos/id123456789"
    }
  ],
  "scope_extensions": [
    {
      "origin": "*.test-opos.com"
    },
    {
      "origin": "test-opos.firebaseapp.com"
    }
  ]
}